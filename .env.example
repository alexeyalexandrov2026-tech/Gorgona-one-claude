# Supabase project (Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only - never expose to the browser. Used by API routes, imports,
# feed sync, and webhook dispatch to bypass RLS with explicit ownership checks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret required in `Authorization: Bearer <CRON_SECRET>` when
# calling /api/cron/sync. Vercel Cron automatically sends this header if
# this env var is named exactly CRON_SECRET; for Cloudflare/other hosts,
# configure your external scheduler to send the same header.
CRON_SECRET=generate-a-long-random-string

# Optional: ticket provider affiliate IDs (see lib/providers.js)
# TICKETMASTER_AFFILIATE_ID=
# STUBHUB_AFFILIATE_ID=
