# ============================================================================
# Gorgona One — AI brain configuration (lib/ai/brain.js).
# Every AI surface on the platform resolves through this one configuration.
# ============================================================================

# OpenRouter API key powering the unified AI brain.
# Create one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Primary model. Default: OpenRouter's free auto-router, which fans requests
# across the currently available free model pool - no purchased credits
# required (free-tier daily request limits apply).
OPENROUTER_MODEL=openrouter/free

# Optional comma-separated fallback chain appended after the primary.
# Leave empty with openrouter/free (it already routes internally); for a paid
# setup use e.g.: anthropic/claude-sonnet-4.5 primary with
# openai/gpt-4o,google/gemini-2.5-flash fallbacks.
OPENROUTER_FALLBACK_MODELS=

# Live web search: 'off' (default), 'native' (provider-native search - paid
# first-party models only), or 'exa' (OpenRouter web plugin, billed per
# search). Keep 'off' while running the free pool.
OPENROUTER_WEB_SEARCH=off

# Optional comma-separated OpenRouter provider allowlist. Leave empty for the
# free pool (it needs provider breadth). For a paid chain, pin first-party
# providers: anthropic,openai,google-ai-studio,google-vertex
OPENROUTER_PROVIDER_ONLY=

# Comma-separated providers excluded from routing. Default blocks Novita,
# which PII-redacts prompt content ("Miami" arrives as "[ADDRESS]"). Set to
# an empty value explicitly to clear the default.
OPENROUTER_PROVIDER_IGNORE=novita,poolside

# ============================================================================
# Canonical inventory repository (lib/data/listings.js).
# ============================================================================

# Supabase project URL + anon (public) key. Reads are protected by RLS -
# only published listings are visible to the anon role. When unset, the
# repository serves the in-repo seed data (lib/*Data.js) as a fallback.
SUPABASE_URL=
SUPABASE_ANON_KEY=
