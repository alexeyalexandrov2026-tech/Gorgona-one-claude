# OpenRouter API key powering the Discovery Room / AI Dock concierge.
# Create one at https://openrouter.ai/settings/keys (paid credits required -
# free-tier models are heavily rate-limited and caused the 429 failures).
OPENROUTER_API_KEY=

# Optional - primary production model (first in the fallback chain).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Optional - comma-separated fallback models OpenRouter re-routes to when the
# primary is rate-limited or down.
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o,google/gemini-2.5-flash
